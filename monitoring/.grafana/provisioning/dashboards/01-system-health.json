{
  "id": null,
  "uid": "fiapx-system-health",
  "title": "FIAP X - System Health (Golden Signals)",
  "tags": ["fiapx", "golden-signals"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "API Latency - Average Response Time",
      "description": "Average response time across all API endpoints",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(video_upload_duration_seconds_sum[5m]) / rate(video_upload_duration_seconds_count[5m])",
          "legendFormat": "Video Upload - Avg",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "pointSize": 5
          }
        }
      }
    },
    {
      "id": 2,
      "title": "API Latency - P95 / P99 Percentiles",
      "description": "Upload duration percentiles (P95 and P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(video_upload_duration_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, rate(video_upload_duration_seconds_bucket[5m]))",
          "legendFormat": "P99",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Traffic - Requests Per Minute (RPM)",
      "description": "Total request rate across all services",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(auth_requests_total[5m])) * 60",
          "legendFormat": "Auth Service RPM",
          "refId": "A"
        },
        {
          "expr": "rate(video_uploads_total[5m]) * 60",
          "legendFormat": "Video Upload RPM",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Traffic - Requests Per Second (RPS)",
      "description": "Instantaneous request rate per second",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(auth_requests_total[1m]))",
          "legendFormat": "Auth RPS",
          "refId": "A"
        },
        {
          "expr": "rate(video_uploads_total[1m])",
          "legendFormat": "Upload RPS",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "title": "Error Rate - Auth Service (4xx / 5xx)",
      "description": "Authentication error rates by endpoint",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(auth_requests_total{endpoint=\"/login\"}[5m])) - sum(rate(auth_requests_total{endpoint=\"/login\"}[5m]))",
          "legendFormat": "Login Errors (estimate)",
          "refId": "A"
        },
        {
          "expr": "rate(auth_requests_total{endpoint=\"/login\"}[5m])",
          "legendFormat": "Login Total {{method}}",
          "refId": "B"
        },
        {
          "expr": "rate(auth_requests_total{endpoint=\"/register\"}[5m])",
          "legendFormat": "Register Total {{method}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Saturation - Process CPU Usage",
      "description": "CPU seconds consumed by each service process",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "rate(process_cpu_seconds_total{job=\"auth-service\"}[5m])",
          "legendFormat": "Auth Service CPU",
          "refId": "A"
        },
        {
          "expr": "rate(process_cpu_seconds_total{job=\"video-upload-service\"}[5m])",
          "legendFormat": "Video Upload CPU",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "opacity"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Saturation - Process Memory (RSS)",
      "description": "Resident memory used by each service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "process_resident_memory_bytes{job=\"auth-service\"}",
          "legendFormat": "Auth Service Memory",
          "refId": "A"
        },
        {
          "expr": "process_resident_memory_bytes{job=\"video-upload-service\"}",
          "legendFormat": "Video Upload Memory",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "gradientMode": "opacity"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 536870912 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
