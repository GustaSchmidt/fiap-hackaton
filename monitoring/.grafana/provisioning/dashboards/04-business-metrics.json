{
  "id": null,
  "uid": "fiapx-business-metrics",
  "title": "FIAP X - Business Metrics",
  "tags": ["fiapx", "business"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Total Videos Uploaded (All Time)",
      "description": "Cumulative count of all video uploads",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "video_uploads_total",
          "legendFormat": "Total Uploads",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "purple", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 2,
      "title": "Total User Registrations (All Time)",
      "description": "Cumulative count of user registrations",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "auth_requests_total{endpoint=\"/register\", method=\"POST\"}",
          "legendFormat": "Registrations",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "purple", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 3,
      "title": "Total Login Sessions (All Time)",
      "description": "Cumulative count of successful login requests",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "auth_requests_total{endpoint=\"/login\", method=\"POST\"}",
          "legendFormat": "Logins",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 10 },
              { "color": "purple", "value": 100 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "title": "Video Upload Volume Over Time",
      "description": "Rate of video uploads over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "increase(video_uploads_total[1h])",
          "legendFormat": "Uploads per Hour",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "#ed145b" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 60,
            "gradientMode": "opacity",
            "showPoints": "never",
            "barAlignment": 0
          }
        }
      }
    },
    {
      "id": 5,
      "title": "User Activity Over Time (Registrations + Logins)",
      "description": "Rate of user registrations and login sessions over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "increase(auth_requests_total{endpoint=\"/register\", method=\"POST\"}[1h])",
          "legendFormat": "Registrations / hour",
          "refId": "A"
        },
        {
          "expr": "increase(auth_requests_total{endpoint=\"/login\", method=\"POST\"}[1h])",
          "legendFormat": "Logins / hour",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "stacking": { "mode": "normal" },
            "showPoints": "never"
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Active Users (Login Rate)",
      "description": "Approximate concurrent user activity based on login frequency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(auth_requests_total{endpoint=\"/login\", method=\"POST\"}[5m]) * 300",
          "legendFormat": "Est. Active Sessions (5m window)",
          "refId": "A"
        },
        {
          "expr": "rate(auth_requests_total{endpoint=\"/me\", method=\"GET\"}[5m]) * 300",
          "legendFormat": "Profile Checks (5m window)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Upload Success Rate",
      "description": "Ratio of successful uploads to total upload attempts",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "1 - (rate(video_uploads_total[1h]) - rate(video_uploads_total[1h])) / rate(video_uploads_total[1h])",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.9 },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "noValue": "100%"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      }
    },
    {
      "id": 8,
      "title": "Average Upload Size (Duration Proxy)",
      "description": "Average upload duration as a proxy for file size complexity",
      "type": "stat",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "rate(video_upload_duration_seconds_sum[1h]) / rate(video_upload_duration_seconds_count[1h])",
          "legendFormat": "Avg Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
