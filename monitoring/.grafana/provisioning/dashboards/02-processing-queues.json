{
  "id": null,
  "uid": "fiapx-processing-queues",
  "title": "FIAP X - Processing (Queue Monitoring)",
  "tags": ["fiapx", "rabbitmq", "processing"],
  "timezone": "browser",
  "editable": true,
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "rabbitmq_job",
        "type": "constant",
        "query": "rabbitmq",
        "current": { "text": "rabbitmq", "value": "rabbitmq" },
        "hide": 2
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "Queue Monitoring Info",
      "type": "text",
      "gridPos": { "h": 3, "w": 24, "x": 0, "y": 0 },
      "options": {
        "mode": "markdown",
        "content": "## RabbitMQ Queue Monitoring\nTo enable full RabbitMQ metrics, add the [RabbitMQ Prometheus plugin](https://www.rabbitmq.com/prometheus.html) and a `rabbitmq` scrape job to `prometheus.yml`:\n```yaml\n- job_name: 'rabbitmq'\n  metrics_path: '/api/metrics'\n  static_configs:\n    - targets: ['rabbitmq:15692']\n```\nPanels below will auto-populate once metrics are available."
      }
    },
    {
      "id": 1,
      "title": "Queue Depth - Messages Ready",
      "description": "Number of messages waiting to be consumed in each queue",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 3 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_ready{queue=\"video_processing_queue\"}",
          "legendFormat": "video_processing_queue - Ready",
          "refId": "A"
        },
        {
          "expr": "rabbitmq_queue_messages_ready{queue=\"notification_queue\"}",
          "legendFormat": "notification_queue - Ready",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 30,
            "gradientMode": "scheme",
            "showPoints": "auto",
            "pointSize": 5
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Queue Depth - Unacknowledged",
      "description": "Messages delivered but not yet acknowledged (being processed)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 3 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages_unacked{queue=\"video_processing_queue\"}",
          "legendFormat": "video_processing_queue - Unacked",
          "refId": "A"
        },
        {
          "expr": "rabbitmq_queue_messages_unacked{queue=\"notification_queue\"}",
          "legendFormat": "notification_queue - Unacked",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "auto"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Video Processing Time (Upload Duration as Proxy)",
      "description": "Time taken for video upload operations (proxy for processing throughput)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "targets": [
        {
          "expr": "rate(video_upload_duration_seconds_sum[5m]) / rate(video_upload_duration_seconds_count[5m])",
          "legendFormat": "Avg Upload Duration",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(video_upload_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 Upload Duration",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Message Publish / Consume Rate",
      "description": "Rate of messages published and consumed per second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "targets": [
        {
          "expr": "rate(rabbitmq_queue_messages_published_total{queue=\"video_processing_queue\"}[5m])",
          "legendFormat": "Published/s - Processing Queue",
          "refId": "A"
        },
        {
          "expr": "rate(rabbitmq_queue_messages_delivered_total{queue=\"video_processing_queue\"}[5m])",
          "legendFormat": "Consumed/s - Processing Queue",
          "refId": "B"
        },
        {
          "expr": "rate(rabbitmq_queue_messages_published_total{queue=\"notification_queue\"}[5m])",
          "legendFormat": "Published/s - Notification Queue",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20,
            "showPoints": "auto"
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Dead Letter Queue (DLQ) Messages",
      "description": "Messages that failed processing and were sent to the dead letter queue",
      "type": "stat",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=~\".*dead.*|.*dlq.*\"}",
          "legendFormat": "DLQ Messages",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "noValue": "0"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 6,
      "title": "Video Processing Status Distribution",
      "description": "Current count of videos by processing status (from upload service)",
      "type": "piechart",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 19 },
      "targets": [
        {
          "expr": "video_uploads_total",
          "legendFormat": "Total Uploaded",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "pieType": "donut",
        "legend": { "displayMode": "list", "placement": "right" }
      }
    },
    {
      "id": 7,
      "title": "RabbitMQ Connections",
      "description": "Total active connections to RabbitMQ",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 19 },
      "targets": [
        {
          "expr": "rabbitmq_connections",
          "legendFormat": "Connections",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          },
          "min": 0,
          "max": 150,
          "noValue": "N/A"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
